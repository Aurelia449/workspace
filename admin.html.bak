<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>后台管理系统 — Supabase CRUD</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --f:-apple-system,"SF Pro Display","Helvetica Neue",sans-serif;
  --bg:#0a0a0f;--s1:#111118;--s2:#18181f;--s3:#1e1e28;
  --fg:#f5f5f7;--gray:#86868b;--gray2:#3a3a42;
  --blue:#0071e3;--cyan:#32ade6;--purple:#bf5af2;
  --green:#30d158;--orange:#ff9f0a;--red:#ff453a;
  --border:rgba(255,255,255,.08);--border2:rgba(255,255,255,.05);
  --grad:linear-gradient(135deg,#0071e3,#bf5af2);
  --sb:230px;
}
html{font-size:14px;height:100%}
body{background:var(--bg);color:var(--fg);font-family:var(--f);-webkit-font-smoothing:antialiased;height:100%;overflow:hidden}
a{text-decoration:none;color:inherit}
button{cursor:pointer;border:none;background:none;font-family:var(--f);color:inherit;font-size:13px}
input,select,textarea{font-family:var(--f);font-size:13px;color:var(--fg)}
::selection{background:var(--blue);color:#fff}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:3px}
code{font-family:"SF Mono","Fira Code",monospace;font-size:12px;background:rgba(255,255,255,.06);padding:2px 6px;border-radius:4px;color:var(--cyan)}

/* ══ LAYOUT ══ */
.layout{display:grid;grid-template-columns:var(--sb) 1fr;grid-template-rows:52px 1fr;height:100vh}

/* ══ TOPBAR ══ */
.topbar{
  grid-column:1/-1;display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;z-index:200;
  background:rgba(10,10,15,.92);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.tb-l{display:flex;align-items:center;gap:14px}
.tb-logo{display:flex;align-items:center;gap:9px}
.tb-mark{width:28px;height:28px;border-radius:7px;background:var(--grad);display:grid;place-items:center;font-size:13px;font-weight:900;color:#fff;box-shadow:0 0 18px rgba(0,113,227,.35)}
.tb-name{font-size:14px;font-weight:700;letter-spacing:-.3px}
.tb-badge{font-size:10px;padding:2px 7px;border-radius:4px;background:rgba(0,113,227,.15);border:1px solid rgba(0,113,227,.3);color:#64a5fa;font-weight:600;letter-spacing:.5px}
.tb-search{display:flex;align-items:center;gap:8px;background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:6px 12px;width:220px;transition:border-color .2s}
.tb-search:focus-within{border-color:rgba(0,113,227,.45)}
.tb-search input{background:none;border:none;outline:none;font-size:13px;color:var(--fg);width:100%}
.tb-search input::placeholder{color:var(--gray2)}
.tb-r{display:flex;align-items:center;gap:10px}
.db-pill{display:inline-flex;align-items:center;gap:6px;font-size:11px;padding:4px 10px;border-radius:6px;background:rgba(255,255,255,.04);border:1px solid var(--border)}
.db-dot{width:6px;height:6px;border-radius:50%;background:var(--gray)}
.db-dot.ok{background:var(--green);box-shadow:0 0 6px rgba(48,209,88,.6);animation:pulse 2s infinite}
.db-dot.err{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

/* ══ SIDEBAR ══ */
.sidebar{
  background:var(--s1);border-right:1px solid var(--border);
  overflow-y:auto;padding:16px 0;
}
.sb-section{font-size:10px;font-weight:700;letter-spacing:1.2px;color:var(--gray);padding:16px 18px 6px;text-transform:uppercase}
.sb-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 18px;margin:1px 8px;border-radius:8px;
  font-size:13px;font-weight:500;cursor:pointer;
  transition:background .15s,color .15s;color:var(--gray);
}
.sb-item:hover{background:var(--s2);color:var(--fg)}
.sb-item.on{background:rgba(0,113,227,.18);color:#64a5fa}
.sb-item .ico{font-size:14px;width:18px;text-align:center}
.sb-item .cnt{margin-left:auto;font-size:11px;background:rgba(255,255,255,.08);padding:2px 7px;border-radius:10px;color:var(--gray)}
.sb-item.on .cnt{background:rgba(0,113,227,.25);color:#64a5fa}

/* ══ MAIN ══ */
.main{overflow-y:auto;background:var(--bg)}
.page{display:none;padding:28px 32px;min-height:100%;animation:fadeIn .2s ease}
.page.on{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}
.ph-l h1{font-size:20px;font-weight:700;letter-spacing:-.5px}
.ph-l p{font-size:13px;color:var(--gray);margin-top:3px}

/* ══ CONNECT SCREEN ══ */
.connect-wrap{
  display:flex;align-items:center;justify-content:center;
  height:calc(100vh - 52px);grid-column:2;
}
.connect-card{
  background:var(--s1);border:1px solid var(--border);border-radius:16px;
  padding:40px;width:480px;max-width:96vw;
}
.connect-card h2{font-size:20px;font-weight:700;margin-bottom:8px;letter-spacing:-.4px}
.connect-card p{font-size:13px;color:var(--gray);margin-bottom:24px;line-height:1.65}
.ff{margin-bottom:16px}
.ff label{display:block;font-size:12px;color:var(--gray);margin-bottom:6px;font-weight:500}
.ff input,.ff select,.ff textarea{
  width:100%;background:var(--s2);border:1px solid var(--border);border-radius:8px;
  padding:10px 12px;outline:none;color:var(--fg);font-size:13px;
  transition:border-color .2s;
}
.ff input:focus,.ff select:focus,.ff textarea:focus{border-color:rgba(0,113,227,.5)}
.ff textarea{resize:vertical;min-height:80px;line-height:1.5}

/* ══ BUTTONS ══ */
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;border:none}
.btn-primary{background:var(--blue);color:#fff}
.btn-primary:hover{background:#0077ed;box-shadow:0 4px 14px rgba(0,113,227,.35)}
.btn-ghost{background:rgba(255,255,255,.06);color:var(--fg);border:1px solid var(--border)}
.btn-ghost:hover{background:rgba(255,255,255,.1)}
.btn-danger{background:rgba(255,69,58,.12);color:var(--red);border:1px solid rgba(255,69,58,.25)}
.btn-danger:hover{background:rgba(255,69,58,.2)}
.btn-green{background:rgba(48,209,88,.12);color:var(--green);border:1px solid rgba(48,209,88,.25)}
.btn-green:hover{background:rgba(48,209,88,.2)}
.btn-sm{padding:6px 12px;font-size:12px;border-radius:7px}
.btn-xs{padding:4px 10px;font-size:11px;border-radius:6px}

/* ══ KPI CARDS ══ */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;margin-bottom:28px}
.kpi{background:var(--s1);border:1px solid var(--border);border-radius:13px;padding:18px 20px;transition:border-color .2s}
.kpi:hover{border-color:rgba(255,255,255,.14)}
.kpi-label{font-size:11px;color:var(--gray);margin-bottom:10px;font-weight:500;letter-spacing:.3px;text-transform:uppercase}
.kpi-val{font-size:28px;font-weight:700;letter-spacing:-1px;margin-bottom:4px}
.kpi-sub{font-size:11px;color:var(--gray)}
.kpi-sub.up{color:var(--green)}
.kpi-sub.warn{color:var(--orange)}

/* ══ TOOLBAR ══ */
.toolbar{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.toolbar input,.toolbar select{
  background:var(--s2);border:1px solid var(--border);border-radius:8px;
  padding:8px 12px;outline:none;color:var(--fg);font-size:13px;
  transition:border-color .2s;
}
.toolbar input:focus,.toolbar select:focus{border-color:rgba(0,113,227,.45)}
.toolbar input{min-width:180px}

/* ══ TABLE ══ */
.tbl-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);background:var(--s1)}
table{width:100%;border-collapse:collapse}
thead tr{border-bottom:1px solid var(--border)}
th{padding:11px 14px;font-size:11px;font-weight:600;color:var(--gray);text-align:left;letter-spacing:.5px;text-transform:uppercase;white-space:nowrap}
td{padding:12px 14px;border-bottom:1px solid var(--border2);font-size:13px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tbody tr{transition:background .12s}
tbody tr:hover{background:rgba(255,255,255,.025)}
.acts{display:flex;gap:6px;align-items:center}
.act{width:28px;height:28px;border-radius:6px;display:grid;place-items:center;font-size:13px;background:rgba(255,255,255,.04);border:1px solid var(--border);transition:all .15s}
.act:hover{background:rgba(255,255,255,.09);transform:scale(1.05)}

/* ══ BADGES ══ */
.badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:3px 9px;border-radius:5px;letter-spacing:.2px;white-space:nowrap}
.b-blue{background:rgba(0,113,227,.18);color:#64a5fa;border:1px solid rgba(0,113,227,.25)}
.b-purple{background:rgba(191,90,242,.18);color:#d49df8;border:1px solid rgba(191,90,242,.25)}
.b-green{background:rgba(48,209,88,.15);color:#5de38b;border:1px solid rgba(48,209,88,.22)}
.b-orange{background:rgba(255,159,10,.15);color:#ffbb44;border:1px solid rgba(255,159,10,.25)}
.b-red{background:rgba(255,69,58,.15);color:#ff7b73;border:1px solid rgba(255,69,58,.22)}
.b-gray{background:rgba(255,255,255,.06);color:var(--gray);border:1px solid var(--border)}
.b-cyan{background:rgba(50,173,230,.15);color:#72d9ff;border:1px solid rgba(50,173,230,.22)}

/* ══ PAGINATION ══ */
.pag{display:none;align-items:center;gap:6px;margin-top:14px}
.pg{width:30px;height:30px;border-radius:7px;display:grid;place-items:center;font-size:12px;font-weight:600;background:rgba(255,255,255,.05);border:1px solid var(--border);transition:all .15s}
.pg:hover{background:rgba(255,255,255,.1)}
.pg.on{background:var(--blue);border-color:var(--blue);color:#fff}
.pg-info{font-size:11px;color:var(--gray);margin-left:8px}

/* ══ EMPTY / LOADING / ERROR ══ */
.empty{text-align:center;padding:48px 20px;color:var(--gray)}
.empty-ico{font-size:36px;margin-bottom:12px}
.loading{display:flex;align-items:center;gap:10px;padding:32px 20px;color:var(--gray);font-size:13px}
.spin{width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}

/* ══ MODAL ══ */
.mbg{position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:20px}
.mbg.on{display:flex}
.modal{background:var(--s2);border:1px solid var(--border);border-radius:16px;width:520px;max-width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 24px 60px rgba(0,0,0,.6)}
.modal-h{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border)}
.modal-h h3{font-size:16px;font-weight:700;letter-spacing:-.3px}
.modal-h button{width:28px;height:28px;border-radius:7px;font-size:16px;background:rgba(255,255,255,.06);display:grid;place-items:center;transition:background .15s}
.modal-h button:hover{background:rgba(255,255,255,.12)}
.modal-b{padding:24px}
.modal-f{padding:16px 24px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px}

/* ══ CONFIRM MODAL ══ */
.cbg{position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center}
.cbg.on{display:flex}
.confirm-box{background:var(--s2);border:1px solid rgba(255,69,58,.3);border-radius:14px;padding:28px;width:380px;text-align:center}
.confirm-box h3{font-size:16px;font-weight:700;margin-bottom:8px}
.confirm-box p{font-size:13px;color:var(--gray);margin-bottom:22px;line-height:1.6}
.confirm-box .acts2{display:flex;gap:10px;justify-content:center}

/* ══ SQL SETUP ══ */
.sql-card{background:var(--s1);border:1px solid var(--border);border-radius:12px;margin-bottom:20px;overflow:hidden}
.sql-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);cursor:pointer;user-select:none}
.sql-header h4{font-size:13px;font-weight:600}
.sql-body{padding:18px;display:none}
.sql-body.open{display:block}
.sql-block{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:14px;margin-bottom:12px;font-family:"SF Mono","Fira Code",monospace;font-size:12px;color:var(--cyan);line-height:1.7;white-space:pre;overflow-x:auto}
.copy-btn{font-size:11px;padding:4px 10px;border-radius:5px;background:rgba(255,255,255,.06);border:1px solid var(--border);cursor:pointer;transition:all .15s;color:var(--gray)}
.copy-btn:hover{background:rgba(255,255,255,.12);color:var(--fg)}

/* ══ SECTION HEADER (in page) ══ */
.sec-h{display:flex;align-items:center;justify-content:space-between;margin:24px 0 12px}
.sec-h h3{font-size:14px;font-weight:700;letter-spacing:-.3px}
.sec-h a{font-size:12px;color:var(--blue);cursor:pointer}
.sec-h a:hover{text-decoration:underline}

/* ══ EXPORT STRIP ══ */
.export-strip{display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:9px;margin-bottom:14px;flex-wrap:wrap}
.export-strip span{font-size:12px;color:var(--gray);flex:1}

/* ══ TOASTS ══ */
#toasts{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:10px;font-size:13px;font-weight:500;background:var(--s3);border:1px solid var(--border);box-shadow:0 8px 24px rgba(0,0,0,.4);animation:slideIn .25s ease;max-width:320px}
.toast.ok{border-color:rgba(48,209,88,.3);background:rgba(48,209,88,.08)}
.toast.er{border-color:rgba(255,69,58,.3);background:rgba(255,69,58,.08)}
.toast.info{border-color:rgba(0,113,227,.3);background:rgba(0,113,227,.08)}
@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}

/* ══ SETTINGS ══ */
.setting-row{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--border)}
.setting-row:last-child{border-bottom:none}
.setting-row .sr-l h4{font-size:13px;font-weight:600;margin-bottom:3px}
.setting-row .sr-l p{font-size:12px;color:var(--gray)}
</style>
</head>
<body>

<!-- ═══════════════ MAIN APP ═══════════════ -->
<div class="layout" id="app" style="display:grid">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="tb-l">
      <div class="tb-logo">
        <div class="tb-mark">⚡</div>
        <span class="tb-name">Admin Console</span>
        <span class="tb-badge">SUPABASE</span>
      </div>
      <div class="tb-search">
        <span style="color:var(--gray);font-size:12px">🔍</span>
        <input id="gsearch" placeholder="全局搜索… (⌘K)"/>
      </div>
    </div>
    <div class="tb-r">
      <div class="db-pill">
        <div class="db-dot" id="db-dot"></div>
        <span id="db-label" style="color:var(--gray)">—</span>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="exportAll()">⬇️ 导出</button>
      <button class="btn btn-danger btn-sm" onclick="disconnectDB()">断开连接</button>
    </div>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sb-section">总览</div>
    <div class="sb-item on" onclick="nav('overview')"><span class="ico">🏠</span>仪表盘</div>

    <div class="sb-section">内容管理</div>
    <div class="sb-item" onclick="nav('news')"><span class="ico">📰</span>公司动态<span class="cnt" id="news-cnt">0</span></div>
    <div class="sb-item" onclick="nav('features')"><span class="ico">🤖</span>AI 功能<span class="cnt" id="feat-cnt">0</span></div>

    <div class="sb-section">工具</div>
    <div class="sb-item" onclick="nav('seed')"><span class="ico">🌱</span>填充示例数据</div>
    <div class="sb-item" onclick="nav('sql')"><span class="ico">📋</span>SQL 建表向导</div>
    <div class="sb-item" onclick="nav('settings')"><span class="ico">⚙️</span>设置</div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- ─── OVERVIEW ─── -->
    <div class="page on" id="page-overview">
      <div class="ph">
        <div class="ph-l"><h1>仪表盘</h1><p>company_news 和 ai_features 数据概览</p></div>
        <button class="btn btn-ghost btn-sm" onclick="refreshAll()">🔄 刷新</button>
      </div>
      <div class="kpi-grid">
        <div class="kpi">
          <div class="kpi-label">公司动态</div>
          <div class="kpi-val" id="kpi-news">—</div>
          <div class="kpi-sub up" id="kpi-news-pub"></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">AI 功能</div>
          <div class="kpi-val" id="kpi-feat">—</div>
          <div class="kpi-sub up" id="kpi-feat-active"></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">草稿</div>
          <div class="kpi-val" id="kpi-draft">—</div>
          <div class="kpi-sub warn">待发布</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">数据库</div>
          <div class="kpi-val" style="font-size:16px;letter-spacing:0" id="kpi-db">—</div>
          <div class="kpi-sub">Supabase</div>
        </div>
      </div>

      <div class="sec-h"><h3>最新公司动态</h3><a onclick="nav('news')">查看全部 →</a></div>
      <div id="ov-news-wrap"></div>

      <div class="sec-h"><h3>AI 功能列表</h3><a onclick="nav('features')">查看全部 →</a></div>
      <div id="ov-feat-wrap"></div>
    </div>

    <!-- ─── NEWS ─── -->
    <div class="page" id="page-news">
      <div class="ph">
        <div class="ph-l"><h1>公司动态</h1><p>表：<code>company_news</code></p></div>
        <button class="btn btn-primary" onclick="openNewsModal()">＋ 新建动态</button>
      </div>
      <div class="toolbar">
        <input id="news-search" placeholder="搜索标题 / 摘要…" oninput="filterNews()"/>
        <select id="news-status-filter" onchange="filterNews()">
          <option value="">全部状态</option>
          <option value="published">已发布</option>
          <option value="draft">草稿</option>
          <option value="archived">已归档</option>
        </select>
        <select id="news-sort" onchange="loadNews()">
          <option value="created_at-desc">最新优先</option>
          <option value="created_at-asc">最旧优先</option>
          <option value="title-asc">标题 A→Z</option>
        </select>
        <button class="btn btn-ghost btn-sm" onclick="loadNews()">🔄 刷新</button>
      </div>
      <div id="news-table-wrap"></div>
      <div class="pag" id="news-pag"></div>
    </div>

    <!-- ─── FEATURES ─── -->
    <div class="page" id="page-features">
      <div class="ph">
        <div class="ph-l"><h1>AI 功能</h1><p>表：<code>ai_features</code></p></div>
        <button class="btn btn-primary" onclick="openFeatModal()">＋ 新建功能</button>
      </div>
      <div class="toolbar">
        <input id="feat-search" placeholder="搜索功能名称 / 描述…" oninput="filterFeatures()"/>
        <select id="feat-status-filter" onchange="filterFeatures()">
          <option value="">全部状态</option>
          <option value="active">已启用</option>
          <option value="beta">Beta</option>
          <option value="inactive">已停用</option>
        </select>
        <select id="feat-category-filter" onchange="filterFeatures()">
          <option value="">全部产品线</option>
          <option value="core">Core</option>
          <option value="vision">Vision</option>
          <option value="voice">Voice</option>
          <option value="guard">Guard</option>
          <option value="finetune">Finetune</option>
        </select>
        <button class="btn btn-ghost btn-sm" onclick="loadFeatures()">🔄 刷新</button>
      </div>
      <div id="feat-table-wrap"></div>
      <div class="pag" id="feat-pag"></div>
    </div>

    <!-- ─── SEED ─── -->
    <div class="page" id="page-seed">
      <div class="ph">
        <div class="ph-l"><h1>填充示例数据</h1><p>快速向两张表插入演示数据</p></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:720px">
        <div style="background:var(--s1);border:1px solid var(--border);border-radius:13px;padding:22px">
          <h3 style="font-size:14px;font-weight:700;margin-bottom:8px">📰 company_news</h3>
          <p style="font-size:12px;color:var(--gray);margin-bottom:16px;line-height:1.6">插入 5 条公司动态示例，涵盖公告、产品、合作等分类。</p>
          <button class="btn btn-green btn-sm" onclick="seedNews()">🌱 填充动态数据</button>
        </div>
        <div style="background:var(--s1);border:1px solid var(--border);border-radius:13px;padding:22px">
          <h3 style="font-size:14px;font-weight:700;margin-bottom:8px">🤖 ai_features</h3>
          <p style="font-size:12px;color:var(--gray);margin-bottom:16px;line-height:1.6">插入 6 个 AI 功能示例，涵盖 Core、Vision、Voice 等产品线。</p>
          <button class="btn btn-green btn-sm" onclick="seedFeatures()">🌱 填充功能数据</button>
        </div>
      </div>
      <div id="seed-log" style="margin-top:20px;font-size:13px;color:var(--gray);line-height:1.8"></div>
    </div>

    <!-- ─── SQL ─── -->
    <div class="page" id="page-sql">
      <div class="ph">
        <div class="ph-l"><h1>SQL 建表向导</h1><p>在 Supabase SQL Editor 中运行以下脚本</p></div>
      </div>
      <div class="sql-card">
        <div class="sql-header" onclick="toggleSqlSection('sql-s1')">
          <h4>① 创建 company_news 表</h4><span style="color:var(--gray);font-size:18px">›</span>
        </div>
        <div class="sql-body" id="sql-s1">
          <div class="sql-block">create table if not exists company_news (
  id         uuid        primary key default gen_random_uuid(),
  title      text        not null,
  summary    text,
  content    text,
  category   text        default 'announcement'
             check (category in ('announcement','product','partnership','event','other')),
  status     text        default 'draft'
             check (status in ('published','draft','archived')),
  cover_url  text,
  author     text        default '管理员',
  tags       text[]      default '{}',
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);</div>
          <button class="copy-btn" onclick="copyEl(this.previousElementSibling)">📋 复制</button>
        </div>
      </div>
      <div class="sql-card">
        <div class="sql-header" onclick="toggleSqlSection('sql-s2')">
          <h4>② 创建 ai_features 表</h4><span style="color:var(--gray);font-size:18px">›</span>
        </div>
        <div class="sql-body" id="sql-s2">
          <div class="sql-block">create table if not exists ai_features (
  id          uuid        primary key default gen_random_uuid(),
  name        text        not null,
  description text,
  category    text        default 'core'
              check (category in ('core','vision','voice','guard','finetune','other')),
  status      text        default 'active'
              check (status in ('active','beta','inactive')),
  icon        text,
  sort_order  int         default 0,
  highlights  text[]      default '{}',
  docs_url    text,
  created_at  timestamptz default now(),
  updated_at  timestamptz default now()
);</div>
          <button class="copy-btn" onclick="copyEl(this.previousElementSibling)">📋 复制</button>
        </div>
      </div>
      <div class="sql-card">
        <div class="sql-header" onclick="toggleSqlSection('sql-s3')">
          <h4>③ Row Level Security（开发阶段允许全部操作）</h4><span style="color:var(--gray);font-size:18px">›</span>
        </div>
        <div class="sql-body" id="sql-s3">
          <div class="sql-block">alter table company_news enable row level security;
alter table ai_features  enable row level security;

create policy "allow all" on company_news
  for all using (true) with check (true);

create policy "allow all" on ai_features
  for all using (true) with check (true);</div>
          <button class="copy-btn" onclick="copyEl(this.previousElementSibling)">📋 复制</button>
        </div>
      </div>
    </div>

    <!-- ─── SETTINGS ─── -->
    <div class="page" id="page-settings">
      <div class="ph">
        <div class="ph-l"><h1>设置</h1><p>当前连接配置</p></div>
      </div>
      <div style="background:var(--s1);border:1px solid var(--border);border-radius:13px;padding:20px 24px;max-width:560px">
        <div class="setting-row">
          <div class="sr-l"><h4>Supabase URL</h4><p id="cfg-display-url" style="font-family:monospace;font-size:11px">—</p></div>
        </div>
        <div class="setting-row">
          <div class="sr-l"><h4>Anon Key</h4><p id="cfg-display-key" style="font-family:monospace;font-size:11px">—</p></div>
        </div>
        <div class="setting-row">
          <div class="sr-l"><h4>连接状态</h4></div>
          <div class="db-pill"><div class="db-dot" id="db-dot2"></div><span id="db-label2" style="color:var(--gray)">—</span></div>
        </div>
        <div style="margin-top:16px;display:flex;gap:10px">
          <button class="btn btn-danger btn-sm" onclick="disconnectDB()">断开并重新配置</button>
          <button class="btn btn-ghost btn-sm" onclick="exportAll()">⬇️ 导出全部数据 (JSON)</button>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /layout -->

<!-- ─── MODAL: NEWS ─── -->
<div class="mbg" id="m-news">
  <div class="modal">
    <div class="modal-h">
      <h3 id="m-news-title">新建公司动态</h3>
      <button onclick="closeModal('m-news')">✕</button>
    </div>
    <div class="modal-b">
      <div class="ff"><label>标题 *</label><input id="n-title" placeholder="动态标题"/></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div class="ff"><label>分类</label>
          <select id="n-category">
            <option value="announcement">📢 公告</option>
            <option value="product">🚀 产品</option>
            <option value="partnership">🤝 合作</option>
            <option value="event">🎉 活动</option>
            <option value="other">📌 其他</option>
          </select>
        </div>
        <div class="ff"><label>状态</label>
          <select id="n-status">
            <option value="draft">◐ 草稿</option>
            <option value="published">● 已发布</option>
            <option value="archived">○ 已归档</option>
          </select>
        </div>
      </div>
      <div class="ff"><label>摘要</label><textarea id="n-summary" rows="2" placeholder="简短描述…"></textarea></div>
      <div class="ff"><label>正文内容</label><textarea id="n-content" rows="4" placeholder="详细内容（支持 Markdown）…"></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div class="ff"><label>作者</label><input id="n-author" placeholder="管理员"/></div>
        <div class="ff"><label>封面图 URL</label><input id="n-cover" placeholder="https://…"/></div>
      </div>
      <div class="ff"><label>标签（逗号分隔）</label><input id="n-tags" placeholder="AI, 产品发布, 融资"/></div>
    </div>
    <div class="modal-f">
      <button class="btn btn-ghost" onclick="closeModal('m-news')">取消</button>
      <button class="btn btn-primary" id="n-save-btn" onclick="saveNews()">💾 保存</button>
    </div>
  </div>
</div>

<!-- ─── MODAL: FEATURE ─── -->
<div class="mbg" id="m-feat">
  <div class="modal">
    <div class="modal-h">
      <h3 id="m-feat-title">新建 AI 功能</h3>
      <button onclick="closeModal('m-feat')">✕</button>
    </div>
    <div class="modal-b">
      <div class="ff"><label>功能名称 *</label><input id="f-name" placeholder="功能名称"/></div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
        <div class="ff"><label>产品线</label>
          <select id="f-category">
            <option value="core">⚡ Core</option>
            <option value="vision">👁️ Vision</option>
            <option value="voice">🎙️ Voice</option>
            <option value="guard">🛡️ Guard</option>
            <option value="finetune">🔧 Finetune</option>
            <option value="other">📌 Other</option>
          </select>
        </div>
        <div class="ff"><label>状态</label>
          <select id="f-status">
            <option value="active">● 已启用</option>
            <option value="beta">β Beta</option>
            <option value="inactive">○ 已停用</option>
          </select>
        </div>
        <div class="ff"><label>排序权重</label><input id="f-sort" type="number" placeholder="0" min="0"/></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 3fr;gap:12px">
        <div class="ff"><label>图标 Emoji</label><input id="f-icon" placeholder="🤖" style="text-align:center;font-size:20px"/></div>
        <div class="ff"><label>功能描述</label><textarea id="f-desc" rows="2" placeholder="一句话描述这个功能…"></textarea></div>
      </div>
      <div class="ff"><label>亮点（逗号分隔）</label><input id="f-highlights" placeholder="实时推理, 多模态支持, 低延迟"/></div>
      <div class="ff"><label>文档链接</label><input id="f-docs" placeholder="https://docs.example.com/feature"/></div>
    </div>
    <div class="modal-f">
      <button class="btn btn-ghost" onclick="closeModal('m-feat')">取消</button>
      <button class="btn btn-primary" id="f-save-btn" onclick="saveFeature()">💾 保存</button>
    </div>
  </div>
</div>

<!-- ─── CONFIRM DELETE ─── -->
<div class="cbg" id="m-confirm">
  <div class="confirm-box">
    <div style="font-size:32px;margin-bottom:12px">🗑️</div>
    <h3 id="confirm-title">确认删除？</h3>
    <p id="confirm-msg">此操作不可撤销，数据将永久从 Supabase 删除。</p>
    <div class="acts2">
      <button class="btn btn-ghost" onclick="closeModal('m-confirm')">取消</button>
      <button class="btn btn-danger" id="confirm-ok">确认删除</button>
    </div>
  </div>
</div>

<!-- TOASTS -->
<div id="toasts"></div>

<script>
/* ══════════════════════════════════
   STATE
══════════════════════════════════ */
let sb = null;
let editingNewsId = null;
let editingFeatId = null;
let allNews = [];
let allFeatures = [];
const PAGE = 15;
let newsPage = 1;
let featPage = 1;

/* ══════════════════════════════════
   CONNECT / DISCONNECT
══════════════════════════════════ */
const SUPABASE_URL = 'https://ddpypwaqldkkbmutsjhv.supabase.co';
const SUPABASE_KEY = 'sb_publishable_wWdYlysOYoYU1mUYzJAQWA_13bgrs3p';

window.addEventListener('DOMContentLoaded', () => {
  // 直接初始化 Supabase，无需任何输入
  sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
  setDbStatus(true, SUPABASE_URL, SUPABASE_KEY);
  refreshAll();

  // Ctrl+K global search
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('gsearch')?.focus();
    }
  });
});

function disconnectDB() {
  sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
  setDbStatus(true, SUPABASE_URL, SUPABASE_KEY);
  toast('🔄 已重新连接', 'ok');
}

function setDbStatus(ok, url='', key='') {
  ['db-dot','db-dot2'].forEach(id => {
    const d = document.getElementById(id);
    if(d) { d.className = 'db-dot ' + (ok ? 'ok' : 'err'); }
  });
  ['db-label','db-label2'].forEach(id => {
    const l = document.getElementById(id);
    if(l) l.textContent = ok ? 'Connected' : 'Error';
  });
  const kpi = document.getElementById('kpi-db');
  if(kpi) kpi.textContent = ok ? '✅ 已连接' : '❌ 断开';
  const du = document.getElementById('cfg-display-url');
  const dk = document.getElementById('cfg-display-key');
  if(du) du.textContent = url || '—';
  if(dk) dk.textContent = key ? key.substring(0,24)+'…' : '—';
}

/* ══════════════════════════════════
   NAVIGATION
══════════════════════════════════ */
function nav(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.sb-item').forEach(s => s.classList.remove('on'));
  const page = document.getElementById('page-' + id);
  if(page) page.classList.add('on');
  document.querySelectorAll('.sb-item').forEach(s => {
    if (s.getAttribute('onclick')?.includes("'"+id+"'")) s.classList.add('on');
  });
  if (id === 'news')     loadNews();
  if (id === 'features') loadFeatures();
}

async function refreshAll() {
  await Promise.all([loadNews(), loadFeatures()]);
  updateOverview();
}

/* ══════════════════════════════════
   OVERVIEW
══════════════════════════════════ */
function updateOverview() {
  const pubNews   = allNews.filter(n => n.status === 'published').length;
  const activeFeat= allFeatures.filter(f => f.status === 'active').length;
  const draft     = allNews.filter(n => n.status === 'draft').length;
  document.getElementById('kpi-news').textContent     = allNews.length || '0';
  document.getElementById('kpi-news-pub').textContent = `已发布 ${pubNews}`;
  document.getElementById('kpi-feat').textContent     = allFeatures.length || '0';
  document.getElementById('kpi-feat-active').textContent = `已启用 ${activeFeat}`;
  document.getElementById('kpi-draft').textContent   = draft || '0';
  document.getElementById('news-cnt').textContent    = allNews.length || '0';
  document.getElementById('feat-cnt').textContent    = allFeatures.length || '0';
  renderOvNews(allNews.slice(0,5));
  renderOvFeat(allFeatures.slice(0,5));
}

function renderOvNews(rows) {
  const w = document.getElementById('ov-news-wrap');
  if (!rows.length) { w.innerHTML = emptyHtml('暂无动态'); return; }
  w.innerHTML = `<div class="tbl-wrap"><table>
    <thead><tr><th>标题</th><th>分类</th><th>状态</th><th>作者</th><th>时间</th></tr></thead>
    <tbody>${rows.map(r=>`<tr>
      <td style="font-weight:500">${esc(r.title||'—')}</td>
      <td>${catBadgeNews(r.category)}</td>
      <td>${stBadgeNews(r.status)}</td>
      <td style="color:var(--gray)">${esc(r.author||'—')}</td>
      <td style="color:var(--gray);font-size:12px">${fmtDate(r.created_at)}</td>
    </tr>`).join('')}</tbody></table></div>`;
}

function renderOvFeat(rows) {
  const w = document.getElementById('ov-feat-wrap');
  if (!rows.length) { w.innerHTML = emptyHtml('暂无功能'); return; }
  w.innerHTML = `<div class="tbl-wrap"><table>
    <thead><tr><th>功能</th><th>产品线</th><th>状态</th><th>排序</th><th>时间</th></tr></thead>
    <tbody>${rows.map(r=>`<tr>
      <td style="font-weight:500">${r.icon?r.icon+' ':''}${esc(r.name||'—')}</td>
      <td>${catBadgeFeat(r.category)}</td>
      <td>${stBadgeFeat(r.status)}</td>
      <td style="color:var(--gray)">${r.sort_order??0}</td>
      <td style="color:var(--gray);font-size:12px">${fmtDate(r.created_at)}</td>
    </tr>`).join('')}</tbody></table></div>`;
}

/* ══════════════════════════════════
   COMPANY NEWS — CRUD
══════════════════════════════════ */
async function loadNews() {
  const wrap = document.getElementById('news-table-wrap');
  if (!wrap) return;
  wrap.innerHTML = loading();
  try {
    const sort = document.getElementById('news-sort')?.value || 'created_at-desc';
    const [col, dir] = sort.split('-');
    const { data, error } = await sb.from('company_news').select('*').order(col, { ascending: dir === 'asc' });
    if (error) throw error;
    allNews = data || [];
    filterNews();
    updateOverview();
  } catch(e) {
    wrap.innerHTML = errorHtml(e.message);
    toast('加载失败：' + e.message, 'er');
  }
}

function filterNews() {
  const q  = (document.getElementById('news-search')?.value||'').toLowerCase();
  const st = document.getElementById('news-status-filter')?.value||'';
  let rows = allNews.filter(r =>
    (!q  || (r.title||'').toLowerCase().includes(q) || (r.summary||'').toLowerCase().includes(q)) &&
    (!st || r.status === st)
  );
  newsPage = 1;
  renderNewsTable(rows);
}

function renderNewsTable(rows) {
  const wrap = document.getElementById('news-table-wrap');
  const pag  = document.getElementById('news-pag');
  if (!rows.length) { wrap.innerHTML = emptyHtml('暂无匹配动态'); pag.style.display='none'; return; }
  const start = (newsPage-1)*PAGE;
  const paged = rows.slice(start, start+PAGE);
  wrap.innerHTML = `<div class="tbl-wrap"><table>
    <thead><tr><th>标题</th><th>分类</th><th>状态</th><th>作者</th><th>标签</th><th>创建时间</th><th>操作</th></tr></thead>
    <tbody>${paged.map(r=>`<tr>
      <td style="font-weight:500;max-width:200px">${esc(r.title||'—')}</td>
      <td>${catBadgeNews(r.category)}</td>
      <td>${stBadgeNews(r.status)}</td>
      <td style="color:var(--gray)">${esc(r.author||'—')}</td>
      <td style="color:var(--gray);font-size:11px">${(r.tags||[]).slice(0,2).join(', ')||'—'}</td>
      <td style="color:var(--gray);font-size:12px">${fmtDate(r.created_at)}</td>
      <td><div class="acts">
        <button class="act" title="编辑" onclick="editNews('${r.id}')">✏️</button>
        <button class="act" title="${r.status==='published'?'撤回':'发布'}" onclick="toggleNewsStatus('${r.id}','${r.status}')">${r.status==='published'?'🔽':'🔼'}</button>
        <button class="act" title="删除" onclick="confirmDelete('news','${r.id}','${esc(r.title||'此条目')}')">🗑️</button>
      </div></td>
    </tr>`).join('')}</tbody></table></div>`;
  const pages = Math.ceil(rows.length/PAGE);
  if (pages<=1) { pag.style.display='none'; return; }
  pag.style.display='flex';
  pag.innerHTML = renderPag(newsPage, pages, 'news');
}

async function saveNews() {
  const title = document.getElementById('n-title').value.trim();
  if (!title) { toast('请填写标题', 'er'); return; }
  const btn = document.getElementById('n-save-btn');
  btn.textContent='保存中…'; btn.disabled=true;
  const payload = {
    title,
    summary:   document.getElementById('n-summary').value.trim()||null,
    content:   document.getElementById('n-content').value.trim()||null,
    category:  document.getElementById('n-category').value,
    status:    document.getElementById('n-status').value,
    cover_url: document.getElementById('n-cover').value.trim()||null,
    author:    document.getElementById('n-author').value.trim()||'管理员',
    tags:      document.getElementById('n-tags').value.split(',').map(t=>t.trim()).filter(Boolean),
    updated_at: new Date().toISOString(),
  };
  if (!editingNewsId) payload.created_at = new Date().toISOString();
  try {
    let error;
    if (editingNewsId) {
      ({ error } = await sb.from('company_news').update(payload).eq('id', editingNewsId));
    } else {
      ({ error } = await sb.from('company_news').insert(payload));
    }
    if (error) throw error;
    toast(editingNewsId ? '动态已更新 ✅' : '动态已创建 ✅', 'ok');
    closeModal('m-news');
    await loadNews();
  } catch(e) {
    toast('保存失败：' + e.message, 'er');
  } finally {
    btn.textContent='💾 保存'; btn.disabled=false;
  }
}

function openNewsModal(id=null) {
  editingNewsId = id;
  const r = id ? allNews.find(n=>n.id==id) : null;
  document.getElementById('m-news-title').textContent = id ? '编辑公司动态' : '新建公司动态';
  document.getElementById('n-title').value    = r?.title||'';
  document.getElementById('n-summary').value  = r?.summary||'';
  document.getElementById('n-content').value  = r?.content||'';
  document.getElementById('n-category').value = r?.category||'announcement';
  document.getElementById('n-status').value   = r?.status||'draft';
  document.getElementById('n-cover').value    = r?.cover_url||'';
  document.getElementById('n-author').value   = r?.author||'管理员';
  document.getElementById('n-tags').value     = (r?.tags||[]).join(', ');
  openModal('m-news');
}

function editNews(id) { openNewsModal(id); }

async function toggleNewsStatus(id, cur) {
  const next = cur==='published'?'draft':'published';
  try {
    const { error } = await sb.from('company_news').update({status:next,updated_at:new Date().toISOString()}).eq('id',id);
    if(error) throw error;
    toast(`状态 → ${next==='published'?'已发布':'草稿'}`, 'ok');
    await loadNews();
  } catch(e) { toast('操作失败：'+e.message, 'er'); }
}

async function deleteNews(id) {
  try {
    const { error } = await sb.from('company_news').delete().eq('id', id);
    if(error) throw error;
    toast('动态已删除', 'ok');
    await loadNews();
  } catch(e) { toast('删除失败：'+e.message, 'er'); }
}

/* ══════════════════════════════════
   AI FEATURES — CRUD
══════════════════════════════════ */
async function loadFeatures() {
  const wrap = document.getElementById('feat-table-wrap');
  if (!wrap) return;
  wrap.innerHTML = loading();
  try {
    const { data, error } = await sb.from('ai_features').select('*').order('sort_order', { ascending: true });
    if(error) throw error;
    allFeatures = data||[];
    filterFeatures();
    updateOverview();
  } catch(e) {
    wrap.innerHTML = errorHtml(e.message);
    toast('加载失败：'+e.message, 'er');
  }
}

function filterFeatures() {
  const q  = (document.getElementById('feat-search')?.value||'').toLowerCase();
  const st = document.getElementById('feat-status-filter')?.value||'';
  const ct = document.getElementById('feat-category-filter')?.value||'';
  let rows = allFeatures.filter(r =>
    (!q  || (r.name||'').toLowerCase().includes(q) || (r.description||'').toLowerCase().includes(q)) &&
    (!st || r.status===st) &&
    (!ct || r.category===ct)
  );
  featPage = 1;
  renderFeatTable(rows);
}

function renderFeatTable(rows) {
  const wrap = document.getElementById('feat-table-wrap');
  const pag  = document.getElementById('feat-pag');
  if (!rows.length) { wrap.innerHTML = emptyHtml('暂无匹配功能'); pag.style.display='none'; return; }
  const start = (featPage-1)*PAGE;
  const paged = rows.slice(start, start+PAGE);
  wrap.innerHTML = `<div class="tbl-wrap"><table>
    <thead><tr><th>功能名称</th><th>产品线</th><th>描述</th><th>状态</th><th>亮点</th><th>排序</th><th>操作</th></tr></thead>
    <tbody>${paged.map(r=>`<tr>
      <td style="font-weight:600;white-space:nowrap">${r.icon?r.icon+' ':''}${esc(r.name||'—')}</td>
      <td>${catBadgeFeat(r.category)}</td>
      <td style="color:var(--gray);font-size:12px;max-width:160px">${esc((r.description||'').substring(0,50))}${(r.description||'').length>50?'…':''}</td>
      <td>${stBadgeFeat(r.status)}</td>
      <td style="color:var(--cyan);font-size:11px">${(r.highlights||[]).slice(0,2).join(' · ')||'—'}</td>
      <td style="color:var(--gray);text-align:center">${r.sort_order??0}</td>
      <td><div class="acts">
        <button class="act" title="编辑" onclick="editFeature('${r.id}')">✏️</button>
        <button class="act" title="${r.status==='active'?'停用':'启用'}" onclick="toggleFeatStatus('${r.id}','${r.status}')">${r.status==='active'?'⏸️':'▶️'}</button>
        <button class="act" title="删除" onclick="confirmDelete('feature','${r.id}','${esc(r.name||'此条目')}')">🗑️</button>
      </div></td>
    </tr>`).join('')}</tbody></table></div>`;
  const pages = Math.ceil(rows.length/PAGE);
  if(pages<=1){ pag.style.display='none'; return; }
  pag.style.display='flex';
  pag.innerHTML = renderPag(featPage, pages, 'feat');
}

async function saveFeature() {
  const name = document.getElementById('f-name').value.trim();
  if (!name) { toast('请填写功能名称', 'er'); return; }
  const btn = document.getElementById('f-save-btn');
  btn.textContent='保存中…'; btn.disabled=true;
  const payload = {
    name,
    description: document.getElementById('f-desc').value.trim()||null,
    category:    document.getElementById('f-category').value,
    status:      document.getElementById('f-status').value,
    icon:        document.getElementById('f-icon').value.trim()||null,
    sort_order:  parseInt(document.getElementById('f-sort').value)||0,
    highlights:  document.getElementById('f-highlights').value.split(',').map(t=>t.trim()).filter(Boolean),
    docs_url:    document.getElementById('f-docs').value.trim()||null,
    updated_at:  new Date().toISOString(),
  };
  if (!editingFeatId) payload.created_at = new Date().toISOString();
  try {
    let error;
    if (editingFeatId) {
      ({ error } = await sb.from('ai_features').update(payload).eq('id', editingFeatId));
    } else {
      ({ error } = await sb.from('ai_features').insert(payload));
    }
    if(error) throw error;
    toast(editingFeatId ? '功能已更新 ✅' : '功能已创建 ✅', 'ok');
    closeModal('m-feat');
    await loadFeatures();
  } catch(e) {
    toast('保存失败：'+e.message, 'er');
  } finally {
    btn.textContent='💾 保存'; btn.disabled=false;
  }
}

function openFeatModal(id=null) {
  editingFeatId = id;
  const r = id ? allFeatures.find(f=>f.id==id) : null;
  document.getElementById('m-feat-title').textContent = id ? '编辑 AI 功能' : '新建 AI 功能';
  document.getElementById('f-name').value       = r?.name||'';
  document.getElementById('f-desc').value       = r?.description||'';
  document.getElementById('f-category').value   = r?.category||'core';
  document.getElementById('f-status').value     = r?.status||'active';
  document.getElementById('f-icon').value       = r?.icon||'';
  document.getElementById('f-sort').value       = r?.sort_order??0;
  document.getElementById('f-highlights').value = (r?.highlights||[]).join(', ');
  document.getElementById('f-docs').value       = r?.docs_url||'';
  openModal('m-feat');
}

function editFeature(id) { openFeatModal(id); }

async function toggleFeatStatus(id, cur) {
  const next = cur==='active'?'inactive':'active';
  try {
    const { error } = await sb.from('ai_features').update({status:next,updated_at:new Date().toISOString()}).eq('id',id);
    if(error) throw error;
    toast(`状态 → ${next==='active'?'已启用':'已停用'}`, 'ok');
    await loadFeatures();
  } catch(e) { toast('操作失败：'+e.message,'er'); }
}

async function deleteFeature(id) {
  try {
    const { error } = await sb.from('ai_features').delete().eq('id', id);
    if(error) throw error;
    toast('功能已删除', 'ok');
    await loadFeatures();
  } catch(e) { toast('删除失败：'+e.message,'er'); }
}

/* ══════════════════════════════════
   SEED DATA
══════════════════════════════════ */
async function seedNews() {
  const log = document.getElementById('seed-log');
  log.innerHTML = '<div class="loading"><div class="spin"></div>正在插入示例动态…</div>';
  const rows = [
    { title:'NOVA AI 完成 B 轮融资，融资额达 5 亿元',   summary:'公司正式宣布完成 B 轮融资，由红杉领投。', category:'announcement', status:'published', author:'公关部', tags:['融资','公司新闻'], created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { title:'全新多模态大模型 NOVA-3 正式发布',         summary:'支持图文视频三模态融合，推理速度提升 3 倍。', category:'product',      status:'published', author:'产品团队', tags:['大模型','多模态'], created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { title:'与中国移动战略合作协议签署',               summary:'双方将在 5G+AI 场景开展深度合作。',          category:'partnership',  status:'published', author:'商务部',   tags:['合作','5G'],     created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { title:'2025 NOVA AI 开发者大会报名开始',          summary:'全球开发者共聚，探索 AI 边界。',            category:'event',        status:'draft',    author:'市场部',   tags:['大会','开发者'], created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { title:'开源 NOVA-Lite 推理框架',                  summary:'轻量级推理引擎，支持边缘设备部署。',         category:'product',      status:'draft',    author:'工程团队', tags:['开源','边缘计算'],created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
  ];
  try {
    const { error } = await sb.from('company_news').insert(rows);
    if(error) throw error;
    log.innerHTML = `<span style="color:var(--green)">✅ 成功插入 ${rows.length} 条公司动态示例数据！</span>`;
    await loadNews();
    toast(`已插入 ${rows.length} 条动态`, 'ok');
  } catch(e) {
    log.innerHTML = `<span style="color:var(--red)">❌ 失败：${e.message}</span>`;
    toast('插入失败：'+e.message, 'er');
  }
}

async function seedFeatures() {
  const log = document.getElementById('seed-log');
  log.innerHTML = '<div class="loading"><div class="spin"></div>正在插入示例功能…</div>';
  const rows = [
    { name:'NOVA Vision Pro',   description:'超高精度图像理解，支持 4K 分辨率实时分析。', category:'vision',   status:'active',   icon:'👁️',  sort_order:1, highlights:['4K实时','零样本识别','多语言 OCR'], created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { name:'NOVA Voice Studio', description:'自然语音合成与识别，支持 50+ 种语言。',     category:'voice',    status:'active',   icon:'🎙️', sort_order:2, highlights:['50+语言','克隆声线','实时转录'],   created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { name:'NOVA Guard',        description:'企业级内容安全过滤，防止有害输出。',         category:'guard',    status:'active',   icon:'🛡️', sort_order:3, highlights:['多维检测','低误报率','实时拦截'],   created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { name:'NOVA Finetune',     description:'私有数据微调平台，10 分钟完成领域适配。',   category:'finetune', status:'beta',     icon:'🔧', sort_order:4, highlights:['LoRA 微调','一键训练','私有部署'],  created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { name:'NOVA Core API',     description:'统一推理接口，兼容 OpenAI 协议。',          category:'core',     status:'active',   icon:'⚡', sort_order:0, highlights:['兼容 OpenAI','流式输出','函数调用'],created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
    { name:'NOVA Code',         description:'专为代码理解与生成优化的模型。',            category:'core',     status:'inactive', icon:'💻', sort_order:5, highlights:['20+语言','代码审查','自动补全'],   created_at:new Date().toISOString(), updated_at:new Date().toISOString() },
  ];
  try {
    const { error } = await sb.from('ai_features').insert(rows);
    if(error) throw error;
    log.innerHTML = `<span style="color:var(--green)">✅ 成功插入 ${rows.length} 个 AI 功能示例数据！</span>`;
    await loadFeatures();
    toast(`已插入 ${rows.length} 个功能`, 'ok');
  } catch(e) {
    log.innerHTML = `<span style="color:var(--red)">❌ 失败：${e.message}</span>`;
    toast('插入失败：'+e.message, 'er');
  }
}

/* ══════════════════════════════════
   EXPORT JSON
══════════════════════════════════ */
function exportAll() {
  const payload = {
    exported_at: new Date().toISOString(),
    company_news: allNews,
    ai_features: allFeatures,
  };
  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `admin-export-${Date.now()}.json`;
  a.click();
  toast('JSON 已导出 ⬇️', 'ok');
}

/* ══════════════════════════════════
   CONFIRM DELETE
══════════════════════════════════ */
function confirmDelete(type, id, name) {
  document.getElementById('confirm-title').textContent = `确认删除「${name}」？`;
  document.getElementById('confirm-msg').textContent   = '此操作不可撤销，数据将从 Supabase 永久删除。';
  document.getElementById('confirm-ok').onclick = async () => {
    closeModal('m-confirm');
    if (type==='news')    await deleteNews(id);
    if (type==='feature') await deleteFeature(id);
  };
  openModal('m-confirm');
}

/* ══════════════════════════════════
   MODAL
══════════════════════════════════ */
function openModal(id)  { document.getElementById(id).classList.add('on');    }
function closeModal(id) { document.getElementById(id).classList.remove('on'); }
document.querySelectorAll('.mbg,.cbg').forEach(bg =>
  bg.addEventListener('click', e => { if(e.target===bg) bg.classList.remove('on'); })
);

/* ══════════════════════════════════
   PAGINATION
══════════════════════════════════ */
function renderPag(cur, total, key) {
  let html='';
  for(let i=1;i<=total;i++){
    if(i===1||i===total||Math.abs(i-cur)<=1){
      const fn = key==='news' ? `newsPage=${i};filterNews()` : `featPage=${i};filterFeatures()`;
      html+=`<button class="pg ${i===cur?'on':''}" onclick="${fn}">${i}</button>`;
    } else if(Math.abs(i-cur)===2){
      html+=`<span style="color:var(--gray);padding:0 3px">…</span>`;
    }
  }
  html+=`<span class="pg-info">共 ${total} 页</span>`;
  return html;
}

/* ══════════════════════════════════
   SQL HELPERS
══════════════════════════════════ */
function toggleSqlGuide() {
  const el = document.getElementById('sql-guide');
  const btn = document.getElementById('sql-toggle-btn');
  const open = el.style.display==='none';
  el.style.display = open?'block':'none';
  btn.textContent = open ? '▲ 隐藏 SQL' : '📋 建表 SQL';
}

function toggleSqlSection(id) {
  const el = document.getElementById(id);
  el.classList.toggle('open');
}

function copySql() {
  const txt = document.getElementById('sql-block-text').textContent;
  navigator.clipboard.writeText(txt).then(()=>toast('SQL 已复制到剪贴板 📋','ok')).catch(()=>toast('复制失败，请手动选取','er'));
}

function copyEl(el) {
  navigator.clipboard.writeText(el.textContent.trim()).then(()=>toast('已复制 📋','ok')).catch(()=>toast('复制失败','er'));
}

/* ══════════════════════════════════
   GLOBAL SEARCH
══════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  const gs = document.getElementById('gsearch');
  if(gs) gs.addEventListener('keydown', e => {
    if(e.key==='Enter'){
      const q = e.target.value.trim().toLowerCase();
      if(!q) return;
      const nr = allNews.filter(r=>(r.title||'').toLowerCase().includes(q));
      if(nr.length){ nav('news'); setTimeout(()=>{ document.getElementById('news-search').value=q; filterNews(); }, 100); toast(`动态中找到 ${nr.length} 条`, 'info'); }
      else { toast('未找到匹配结果', 'info'); }
      e.target.value='';
    }
  });
});

/* ══════════════════════════════════
   BADGES & UTILS
══════════════════════════════════ */
function stBadgeNews(s) {
  const m={published:['b-green','● 已发布'],draft:['b-orange','◐ 草稿'],archived:['b-gray','○ 已归档']};
  const[c,t]=m[s]||['b-gray',s||'—'];
  return `<span class="badge ${c}">${t}</span>`;
}
function catBadgeNews(c) {
  const m={announcement:'b-blue',product:'b-purple',partnership:'b-green',event:'b-orange',other:'b-gray'};
  const l={announcement:'📢 公告',product:'🚀 产品',partnership:'🤝 合作',event:'🎉 活动',other:'📌 其他'};
  return `<span class="badge ${m[c]||'b-gray'}">${l[c]||c||'—'}</span>`;
}
function stBadgeFeat(s) {
  const m={active:['b-green','● 已启用'],beta:['b-orange','β Beta'],inactive:['b-gray','○ 已停用']};
  const[c,t]=m[s]||['b-gray',s||'—'];
  return `<span class="badge ${c}">${t}</span>`;
}
function catBadgeFeat(c) {
  const m={core:'b-blue',vision:'b-purple',voice:'b-green',guard:'b-red',finetune:'b-orange',other:'b-gray'};
  const ico={core:'⚡',vision:'👁️',voice:'🎙️',guard:'🛡️',finetune:'🔧',other:'📌'};
  return `<span class="badge ${m[c]||'b-gray'}">${(ico[c]||'')} ${(c||'—').toUpperCase()}</span>`;
}
function fmtDate(iso) {
  if(!iso) return '—';
  try{ return new Date(iso).toLocaleDateString('zh-CN',{month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'}); }
  catch{ return iso.substring(0,10); }
}
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function emptyHtml(m){ return `<div class="empty"><div class="empty-ico">📭</div><p>${m}</p></div>`; }
function errorHtml(m){ return `<div class="empty"><div class="empty-ico">⚠️</div><p style="color:var(--red)">${m}</p></div>`; }
function loading()    { return `<div class="loading"><div class="spin"></div>加载中…</div>`; }

/* ══════════════════════════════════
   TOAST
══════════════════════════════════ */
function toast(msg, type='info') {
  const icons={ok:'✅',er:'❌',info:'ℹ️'};
  const el=document.createElement('div');
  el.className=`toast ${type}`;
  el.innerHTML=`<span>${icons[type]||'ℹ️'}</span><span>${msg}</span>`;
  document.getElementById('toasts').appendChild(el);
  setTimeout(()=>{ el.style.cssText='opacity:0;transform:translateX(20px);transition:all .3s'; setTimeout(()=>el.remove(),320); },3000);
}
</script>
</body>
</html>

